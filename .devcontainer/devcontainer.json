{
  "name": "UmbracoDevContainer",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "containerEnv": {
    "UMBRACO_USER_NAME": "${localEnv:UMBRACO_USER_NAME}",
    "UMBRACO_USER_EMAIL": "${localEnv:UMBRACO_USER_EMAIL}",
    "UMBRACO_USER_PASSWORD": "${localEnv:UMBRACO_USER_PASSWORD}",
    "SQL_SA_PASSWORD": "${localEnv:SQL_SA_PASSWORD}",
    "DEVCONTAINER_CERT_PASSWORD": "${localEnv:DEVCONTAINER_CERT_PASSWORD}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "GitHub.copilot-chat",
        "openai.chatgpt",
        "microsoft-aspire.aspire-vscode",
        "ms-dotnettools.csharp",
        "ms-azuretools.vscode-docker",
        "ms-azuretools.vscode-azurefunctions",
        "ms-vscode.azurecli"
      ]
    }
  },
  "runServices": [
    "sql",
    "azurite",
    "appconfig",
    "aspire-dashboard"
  ],
  "initializeCommand": "pwsh -NoProfile -ExecutionPolicy Bypass -File .devcontainer/setup-dev-cert.ps1",
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "postStartCommand": "bash /workspace/.devcontainer/post-start.sh"
}
