{
  "$schema": "appsettings-schema.json",
  "ConnectionStrings": {
    "umbracoDbDSN": "Server=sql,1433;Database=UmbracoDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;",
    "umbracoDbDSN_ProviderName": "System.Data.SqlClient"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            },
            {
              "Name": "OpenTelemetry",
              "Args": {
                "endpoint": "http://aspire-dashboard:18889",
                "protocol": "Grpc"
              }
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Hosting": {
        "Debug": true
      }
    }
  }
}
