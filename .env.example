# Umbraco unattended installation environment variables
# Copy this file to .env and set your desired values

UMBRACO_USER_NAME=admin@example.com
UMBRACO_USER_EMAIL=admin@example.com
UMBRACO_USER_PASSWORD=Admin123456!

# Dev Container - SQL Server sa password
SQL_SA_PASSWORD=Your_password123

# Dev Container - HTTPS certificate password
DEVCONTAINER_CERT_PASSWORD=devcontainer-local-password
